# --- Storage ---
# Local dev uses SQLite. Production swaps to Postgres or Vercel KV.
DATABASE_URL="file:./dev.db"

# --- Base RPC ---
# Public endpoints are rate-limited. For polish use Alchemy / Infura / a Base
# dedicated node provider. The same URL ships server-side and to the client.
BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# --- KairoPolicy on-chain registry ---
# Canonical Kairo deployment on Base Sepolia. The web app and the Steward
# agent both read from this address as the source of truth. To deploy your
# own (e.g. mainnet), run `pnpm contracts:build && forge script script/Deploy.s.sol`.
NEXT_PUBLIC_KAIRO_POLICY_ADDRESS="0xE08065110d0d7E63582942447973f895bC35B13A"

# --- WalletConnect / RainbowKit ---
# Optional. Without a projectId, WalletConnect is skipped but injected wallets
# (MetaMask, Rabby, Coinbase Wallet) still work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# --- App URL ---
# Used for receipt permalinks and OG image generation.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Steward agent ---
STEWARD_API_KEY="dev-only-not-secret"
