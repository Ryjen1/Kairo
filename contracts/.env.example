# Copy this file to .env (which is git-ignored) and fill in your values.
# NEVER commit .env. NEVER share your private key with anyone, ever.

# --- Base Sepolia RPC ---
# Public endpoint works but is rate-limited. For polish use Alchemy / Infura.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# --- Deployer private key ---
# Use a FRESH wallet you create just for deploying. Funded with a few drops of
# Sepolia ETH from a faucet (https://www.alchemy.com/faucets/base-sepolia).
# Format: 64-char hex string, with or without 0x prefix.
PRIVATE_KEY=

# --- Basescan API key (optional) ---
# For contract verification. Sign up free at https://basescan.org/myapikey.
# If empty, deploy still works but the contract won't show source on Basescan.
BASESCAN_API_KEY=
